{
  "name": "jamrah",
  "version": "1.3.0",
  "description": "Jamrah جَــمْــرَه — ember of productivity. Pomodoro timer, habits tracker & more",
  "main": "main.js",
  "author": "AhmMed29",
  "license": "GPL-3.0-only",
  "scripts": {
    "postinstall": "npx @electron/rebuild",
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.ahmmed.jamrah",
    "productName": "Jamrah",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "Jamrah-Icon.png",
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/Jamrah-Icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "AhmMed29",
      "repo": "jamrah"
    }
  },
  "type": "commonjs",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.35.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.3.9"
  }
}
